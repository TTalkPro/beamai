{application, beamai_core, [
    {description, "BeamAI Core - Kernel 框架"},
    {vsn, "1.0.0"},
    {registered, [beamai_core_sup, beamai_http_pool]},
    {mod, {beamai_core_app, []}},
    {applications, [kernel, stdlib, jsx, uuid, hackney]},
    {optional_applications, [gun, beamai_llm]},
    {env, []},
    {modules, [
        %% OTP 应用
        beamai_core_app,
        beamai_core_sup,
        %% Facade 入口
        beamai,
        %% Kernel 核心
        beamai_kernel,
        beamai_message,
        beamai_tool,
        beamai_tool_behaviour,
        beamai_context,
        beamai_result,
        beamai_prompt,
        beamai_llm_response,
        %% Filter（洋葱式过滤器）
        beamai_filter,
        beamai_filter_chain,
        %% 行为接口
        beamai_chat_behaviour,
        beamai_http_behaviour,
        beamai_chat_memory,
        beamai_memory_provider,
        %% 会话记忆（Memory Filter 机制）
        beamai_chat_memory_ets,
        beamai_memory_provider_default,
        beamai_memory_filter,
        %% HTTP 客户端
        beamai_http,
        beamai_http_hackney,
        beamai_http_gun,
        beamai_http_pool,
        %% JSON-RPC
        beamai_jsonrpc,
        %% SSE
        beamai_sse,
        %% 工具
        beamai_id,
        beamai_utils
    ]},
    {licenses, ["Apache-2.0"]},
    {links, []}
]}.
