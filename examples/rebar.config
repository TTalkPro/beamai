{erl_opts, [debug_info]}.

{src_dirs, ["src"]}.

%% beamai 依赖通过 ERL_LIBS 环境变量提供
%% 使用方式:
%%   ERL_LIBS=../_build/default/lib rebar3 compile
%%   ERL_LIBS=../_build/default/lib rebar3 shell

{deps, [
    {poolboy, "1.5.2"}
]}.

%% 只需启动 beamai_core：HTTP 后端 gun 是它的硬依赖，会被自动带起。
{shell, [
    {apps, [beamai_core]}
]}.
